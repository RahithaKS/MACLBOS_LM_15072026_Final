# ================================
# LedgerLM Environment Variables
# FOR: Bosch VM with Existing PostgreSQL
# ================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to Git!

# ================================
# PostgreSQL Connection (EXISTING ON VM)
# ================================
# These are the credentials for PostgreSQL already installed on the VM
# Ask Bosch IT for these values, OR check the VM's PostgreSQL config

# Host: Usually 172.17.0.1 (Docker's gateway to host) or localhost
POSTGRES_HOST=172.17.0.1

# Port: Usually 5432 (default PostgreSQL port)
POSTGRES_PORT=5432

# Database name: Ask Bosch or create one
POSTGRES_DB=ledgerlm

# Username: Ask Bosch or check pg_hba.conf
POSTGRES_USER=ledgerlm

# Password: Ask Bosch IT for this!
POSTGRES_PASSWORD=ASK_BOSCH_FOR_THIS_PASSWORD

# ================================
# Application Settings
# ================================
APP_PORT=80
SESSION_SECRET=generate_a_random_32_char_string_here

# ================================
# OpenAI API Key
# ================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ================================
# Email Configuration (SMTP)
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@ledgerlm.com

# ================================
# Hardcoded Admin OTP
# ================================
NEMKO_ADMIN_OTP=123456

# ================================
# Anaplan Integration (Optional)
# ================================
ANAPLAN_WORKSPACE_ID=
ANAPLAN_MODEL_ID=
ANAPLAN_PROCESS_ID=118000000093
ANAPLAN_USERNAME=
ANAPLAN_PASSWORD=

# ================================
# Google Search (Optional)
# ================================
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ================================
# Docker Image
# ================================
DOCKER_IMAGE=boschledgerlm.azurecr.io/ledgerlm:latest
