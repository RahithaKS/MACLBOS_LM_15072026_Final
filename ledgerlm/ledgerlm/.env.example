# ================================
# LedgerLM Environment Variables
# ================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to Git!

# ================================
# Database Configuration
# ================================
POSTGRES_USER=ledgerlm
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=ledgerlm
POSTGRES_PORT=5432

# ================================
# Application Settings
# ================================
APP_PORT=80
SESSION_SECRET=generate_a_random_32_char_string_here

# ================================
# OpenAI API Key
# ================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ================================
# Email Configuration (SMTP)
# ================================
# For sending OTP login codes
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@ledgerlm.com

# ================================
# Hardcoded Admin OTP (Optional)
# ================================
# If set, this OTP will always work for nemkomatasma@nemko.com
# Useful for initial setup and testing
NEMKO_ADMIN_OTP=123456

# ================================
# Anaplan Integration (Optional)
# ================================
# For automated data sync from Anaplan
ANAPLAN_WORKSPACE_ID=
ANAPLAN_MODEL_ID=
ANAPLAN_PROCESS_ID=118000000093
ANAPLAN_USERNAME=
ANAPLAN_PASSWORD=

# ================================
# Google Search (Optional)
# ================================
# For web search feature in AI chat
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ================================
# Docker Image (for deployment)
# ================================
DOCKER_IMAGE=boschledgerlm.azurecr.io/ledgerlm:latest
