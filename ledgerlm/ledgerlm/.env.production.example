# ================================
# LedgerLM Production Environment Variables
# ================================
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to Git!

# ---------------------------
# Database
# ---------------------------
POSTGRES_USER=ledgerlm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ledgerlm
POSTGRES_PORT=5432

# ---------------------------
# Application
# ---------------------------
APP_PORT=80
SESSION_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS

# ---------------------------
# OpenAI API
# ---------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---------------------------
# Email (SMTP)
# ---------------------------
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@bosch.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=ledgerlm@bosch.com

# ---------------------------
# Anaplan Integration
# ---------------------------
ANAPLAN_WORKSPACE_ID=8a868cdc7e5feca9017e8e4afdd57430
ANAPLAN_MODEL_ID=BE462879B50444F498A0DA70F40FABA2
ANAPLAN_PROCESS_ID=118000000093
ANAPLAN_USERNAME=your-anaplan-username
ANAPLAN_PASSWORD=your-anaplan-password

# ---------------------------
# Google Search (Optional)
# ---------------------------
GOOGLE_SEARCH_API_KEY=your-google-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# ---------------------------
# Keycloak (SSO)
# ---------------------------
KEYCLOAK_HOSTNAME=keycloak.bosch.com
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---------------------------
# Special Access (Remove in production!)
# ---------------------------
NEMKO_ADMIN_OTP=123456
