# ================================
# LedgerLM GPU Production Environment
# ================================
# Copy this file to .env and fill in your values
# For Bosch VM with NVIDIA Tesla T4 GPU

# ================================
# DATABASE (PostgreSQL on VM)
# ================================
POSTGRES_USER=ledgerlm_app
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE
POSTGRES_HOST=172.17.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ledgerlm

# ================================
# OpenAI API Key
# ================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR-KEY-HERE

# ================================
# Email (SMTP Settings)
# ================================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=ledgerlm@bosch.com

# ================================
# Session Security
# ================================
# Generate a random 32-character string
# You can use: openssl rand -hex 16
SESSION_SECRET=YOUR_RANDOM_32_CHARACTER_STRING

# ================================
# Anaplan Integration (Optional)
# ================================
# Leave blank if not using Anaplan
ANAPLAN_WORKSPACE_ID=
ANAPLAN_MODEL_ID=
ANAPLAN_PROCESS_ID=
ANAPLAN_USERNAME=
ANAPLAN_PASSWORD=

# ================================
# Google Search (Optional)
# ================================
# For web search integration
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ================================
# Admin OTP (Optional)
# ================================
NEMKO_ADMIN_OTP=

# ================================
# Application Ports
# ================================
APP_PORT=80
HTTPS_PORT=443
